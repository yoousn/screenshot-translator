diff --git a/server/tests/test_cache.py b/server/tests/test_cache.py
index 517ab39..validation-fixes 100644
--- a/server/tests/test_cache.py
+++ b/server/tests/test_cache.py
@@ -28,3 +28,15 @@ def test_cache_lru_and_ttl():
     assert cache.get(cache.make_key("one", "en", "zh", "google", "1.0")) == "1"
     assert cache.get(cache.make_key("three", "en", "zh", "google", "1.0")) == "3"
     assert cache.get(cache.make_key("four", "en", "zh", "google", "1.0")) == "4"
+
+
+def test_cache_ttl_uses_monotonic_clock(monkeypatch):
+    cache = TranslationCache(maxsize=3, ttl_seconds=1)
+    key = cache.make_key("clock sensitive", "en", "zh", "google", "1.0")
+
+    fake_now = {"value": 100.0}
+    monkeypatch.setattr("translator.time.perf_counter", lambda: fake_now["value"])
+    cache.set(key, "ok")
+    assert cache.get(key) == "ok"
+    fake_now["value"] = 102.0
+    assert cache.get(key) is None
