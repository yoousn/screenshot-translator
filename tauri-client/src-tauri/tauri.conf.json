{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YsnTrans",
  "version": "1.2.5",
  "identifier": "com.screenshot.translator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YsnTrans",
        "label": "main",
        "width": 1200,
        "height": 800,
        "visible": false,
        "resizable": true
      },
      {
        "title": "YSN 截图辅助窗口",
        "label": "screenshot",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$LOCALDATA/ScreenshotTranslator/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/rapidocr/": "resources/rapidocr/",
      "resources/ffmpeg/": "resources/ffmpeg/",
      "../../models/rapidocr/": "models/rapidocr/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
